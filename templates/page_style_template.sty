% templates/page_style_template.sty
\ProvidesPackage{page_style}[2026/07/06 Imprint Image+Text Page Style]

\RequirePackage{fontspec}
\RequirePackage{xeCJK}
\RequirePackage{geometry}
\RequirePackage[absolute,overlay]{textpos}
\RequirePackage{graphicx}

% 한국어는 어절 단위 공백이 의미를 가지므로 xeCJK의 공백 무시 기본값을 꺼야 한다.
\xeCJKsetup{CJKspace = true}

\geometry{
  paperwidth={{PAGE_WIDTH}}mm,
  paperheight={{PAGE_HEIGHT}}mm,
  top={{MARGIN_TOP}}mm,
  bottom={{MARGIN_BOTTOM}}mm,
  inner={{MARGIN_INNER}}mm,
  outer={{MARGIN_OUTER}}mm,
}
\setlength{\TPHorizModule}{1mm}
\setlength{\TPVertModule}{1mm}

% 본문 세리프: PRD 지정 Noto Serif KR은 이 PC에 정적 폰트가 없어(가변폰트만 존재,
% xdvipdfmx 임베드 실패 이력) IBM Plex Serif로 대체한다.
% 주의: {{{FONTS_DIR}}/} 처럼 중괄호가 3~4개 겹쳐 보이는 곳은 LaTeX 문법용 리터럴 중괄호 1개와
% 이중 중괄호로 감싼 치환 토큰(중괄호 2개)이 겹쳐진 것이다 — 치환 후에는 { .../ } 형태의 정상적인
% LaTeX 그룹 하나가 된다. 폰트 파라미터를 추가/수정할 때 중괄호 개수를 세어보고 맞출 것.
\setmainfont{{{BODY_FONT_FILE_EN}}}[
  Path = {{{FONTS_DIR}}/}, Extension = .{{BODY_FONT_FILE_EXT}}, BoldFont = {{{BODY_FONT_FILE_BOLD}}},
]
\setCJKmainfont{{{BODY_FONT_FILE_KR}}}[
  Path = {{{FONTS_DIR}}/}, Extension = .{{BODY_FONT_FILE_EXT}}, BoldFont = {{{BODY_FONT_FILE_KR_BOLD}}},
]

\newcommand{\BodyText}[1]{\fontsize{{{BODY_FONT_SIZE}}pt}{{{BODY_LEADING}}pt}\selectfont #1\par}

% Role-based text styles for modular paragraph layouts
% Enables different visual emphasis for section titles, case studies, body text, and credits
\newcommand{\SectionTitleText}[1]{\fontsize{14pt}{16pt}\selectfont\bfseries #1\par}
\newcommand{\CaseTitleKoText}[1]{\fontsize{11pt}{13pt}\selectfont\bfseries #1\par}
\newcommand{\CaseTitleEnText}[1]{\fontsize{10pt}{12pt}\selectfont\bfseries\MakeUppercase{#1}\par}
\newcommand{\CaseBodyText}[1]{\fontsize{{{BODY_FONT_SIZE}}pt}{{{BODY_LEADING}}pt}\selectfont #1\par}
\newcommand{\CreditText}[1]{\fontsize{7pt}{9pt}\selectfont\itshape #1\par}

% 제목(섹션 오프너) 전용 서체: PRD 4.5의 제목/구조용 산세리프인 Noto Sans KR을
% 본문 세리프(IBM Plex Serif)와는 별도의 폰트 패밀리로 선언한다.
\newfontfamily\HeadingENFace{{{HEADING_FONT_FILE_EN}}}[
  Path = {{{FONTS_DIR}}/}, Extension = .{{HEADING_FONT_FILE_EXT}}, BoldFont = {{{HEADING_FONT_FILE_BOLD}}},
]
\newCJKfontfamily\HeadingKRFace{{{HEADING_FONT_FILE_KR}}}[
  Path = {{{FONTS_DIR}}/}, Extension = .{{HEADING_FONT_FILE_EXT}}, BoldFont = {{{HEADING_FONT_FILE_KR_BOLD}}},
]
\newcommand{\HeadingFontSet}{\HeadingENFace\HeadingKRFace}
\newcommand{\TitleText}[1]{{\HeadingFontSet\bfseries\fontsize{{{TITLE_FONT_SIZE}}pt}{{{TITLE_LEADING}}pt}\selectfont #1\par}}

\pagestyle{empty}
\endinput
